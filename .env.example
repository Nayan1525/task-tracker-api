# Copy to .env for local development. Never commit a real .env (it's
# gitignored). See core/configuration-secrets.md.

# SQLAlchemy database URL (psycopg v3 driver). Matches docker-compose.yml
# (host port 5433, chosen to avoid colliding with a system Postgres on 5432).
DATABASE_URL=postgresql+psycopg://task_tracker:task_tracker@localhost:5433/task_tracker

# development | staging | production
ENVIRONMENT=development

# Root log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
